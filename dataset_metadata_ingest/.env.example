# =========================
# 필수
# =========================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_db
PARSER_VERSION=v1.0.0

# =========================
# 일반 동작 옵션
# =========================
REQUEST_TIMEOUT_SECONDS=45
CONNECT_TIMEOUT_SECONDS=20
SAVE_EVERY=25
MAX_PER_SOURCE=0
SAFE_MODE_DEFAULT=true
DEFAULT_SAFE_LIMIT=20
MAX_SAFE_LIMIT=100
PER_SOURCE_COOLDOWN_SECONDS=20
BATCH_PAUSE_EVERY=10
BATCH_PAUSE_SECONDS=8
MIN_REQUEST_INTERVAL_SECONDS=1.2
REQUEST_INTERVAL_JITTER_SECONDS=0.5
RETRY_STATUS_CODES=408,409,425,429,500,502,503,504
RETRY_MAX_SLEEP_SECONDS=30
DEEP_ENRICHMENT=false
VERIFY_SSL=true
USER_AGENT=dataset-metadata-ingest/1.0 (+https://example.local; contact=admin@example.local)

# =========================
# 선택 API 키 / 인증정보
# =========================
# Hugging Face는 공개 메타데이터 기준 없어도 동작
HUGGINGFACE_TOKEN=

# Kaggle
# 방법 1) 아래 2개 직접 입력
KAGGLE_USERNAME=
KAGGLE_KEY=
# 방법 2) kaggle.json 위치 지정 (없으면 기본 ~/.kaggle 사용)
KAGGLE_CONFIG_DIR=

# data.gov catalog (필수)
DATA_GOV_API_KEY=

# AWS ODR
# 현재 기본 구현은 공식 공개 YAML/Registry 메타데이터를 사용하므로 없어도 동작
AWS_ODR_API_KEY=
# GitHub rate limit 완화를 위해 권장
GITHUB_TOKEN=

# =========================
# 크롤링 대상 URL override
# =========================
PUBLIC_DATA_PORTAL_LIST_URL_TEMPLATE=https://www.data.go.kr/en/tcs/dss/selectDataSetList.do?pageIndex={page}&dType=FILE
AIHUB_LIST_URL_TEMPLATE=https://www.aihub.or.kr/aihubdata/data/list.do?currMenu=115&pageIndex={page}
